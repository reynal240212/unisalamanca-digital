{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/public/login.html" },
    { "source": "/login", "destination": "/public/login.html" },
    { "source": "/admin", "destination": "/public/admin/index.html" },
    { "source": "/student", "destination": "/public/student/index.html" },
    { "source": "/validator", "destination": "/public/validator/index.html" },
    { "source": "/images/(.*)", "destination": "/public/images/$1" },
    { "source": "/styles/(.*)", "destination": "/public/styles/$1" },
    { "source": "/scripts/(.*)", "destination": "/public/scripts/$1" },
    { "source": "/src/(.*)", "destination": "/public/src/$1" },
    { "source": "/uploads/(.*)", "destination": "/public/uploads/$1" },
    { "source": "/admin/(.*)", "destination": "/public/admin/$1" },
    { "source": "/student/(.*)", "destination": "/public/student/$1" },
    { "source": "/validator/(.*)", "destination": "/public/validator/$1" }
  ]
}
